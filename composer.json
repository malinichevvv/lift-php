{
    "name": "lift-php/lift",
    "description": "The lifting PHP micro-framework",
    "keywords": ["framework", "micro-framework", "php", "http", "router", "di", "psr"],
    "homepage": "https://github.com/lift-php/lift",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/container": "^2.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "Lift\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lift\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/lift"],
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=8"
    },
    "suggest": {
        "ext-redis": "Required for RedisClient, RedisCache, and RedisQueue drivers.",
        "ext-pcntl": "Enables graceful SIGTERM/SIGINT handling in the queue Worker."
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
