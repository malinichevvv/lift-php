{
    "name": "malinichevvv/lift-php",
    "description": "A fast, minimal PHP micro-framework — PSR-7/11/15, autowiring DI, routing, and zero config",
    "keywords": ["framework", "micro-framework", "php", "http", "router", "psr-7", "psr-11", "psr-15", "middleware", "di-container"],
    "homepage": "https://getlift.dev",
    "license": "MIT",
    "type": "library",
    "support": {
        "docs":   "https://getlift.dev",
        "issues": "https://github.com/malinichevvv/lift-php/issues",
        "source": "https://github.com/malinichevvv/lift-php"
    },
    "require": {
        "php": ">=8.1",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.1",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "psr/container": "^2.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "Lift\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lift\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/lift"],
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=8",
        "lift": "@php vendor/bin/lift"
    },
    "suggest": {
        "ext-redis": "Required for RedisClient, RedisCache, and RedisQueue drivers.",
        "ext-pcntl": "Enables graceful SIGTERM/SIGINT handling in the queue Worker.",
        "php-amqplib/php-amqplib": "Required for AmqpQueue (RabbitMQ driver). Install: composer require php-amqplib/php-amqplib \"^3.0\""
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
